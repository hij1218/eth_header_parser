          <mxGeometry x="785" y="328" width="150" height="25" as="geometry"/>
        </mxCell>

        <!-- WORD 4 -->
        <mxCell id="w4h" value="&lt;b&gt;Word 4&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#333;fillColor=#f5f5f5;" vertex="1" parent="1">
