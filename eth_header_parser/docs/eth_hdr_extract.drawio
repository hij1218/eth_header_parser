          <mxGeometry x="1220" y="150" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="w5_0v_ip6" value="&lt;b&gt;No VLAN IPv6:&lt;/b&gt;&lt;br&gt;dst_addr mid [63:0]" style="rounded=0;fillColor=#FFF9E6;strokeColor=#CCCC99;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1220" y="228" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="w5_2v" value="&lt;b&gt;2 VLAN + IPv4:&lt;/b&gt;&lt;br&gt;src_ip, dst_ip_hi" style="rounded=0;fillColor=#FFF9E6;strokeColor=#CCCC99;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1220" y="275" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="w5_lat" value="&lt;b&gt;T+6&lt;/b&gt; (1V IPv4)" style="text;html=1;align=center;fontSize=9;fontColor=#CC6600;fillColor=#FFF9E6;rounded=1;strokeColor=#CCCC99;" vertex="1" parent="1">
          <mxGeometry x="1225" y="325" width="140" height="25" as="geometry"/>
        </mxCell>

        <!-- WORD 6-7 -->
        <mxCell id="w67h" value="&lt;b&gt;Word 6-7&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="1390" y="100" width="180" height="30" as="geometry"/>
