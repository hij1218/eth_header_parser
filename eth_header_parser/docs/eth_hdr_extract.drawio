        <mxCell id="eth_rest" value="&lt;font color=&quot;#999&quot;&gt;... payload ...&lt;/font&gt;" style="rounded=0;fillColor=#f5f5f5;strokeColor=#CCC;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="530" width="600" height="45" as="geometry"/>
        </mxCell>

        <!-- 3 branching paths -->
        <!-- No VLAN -->
        <mxCell id="nv_box" value="" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="610" width="280" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="nv_title" value="&lt;b&gt;Path A: No VLAN&lt;/b&gt;     vlan_count = &quot;00&quot;" style="text;html=1;align=left;fontSize=11;fontColor=#333;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="618" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="nv_cond" value="EtherType != 0x8100, != 0x88A8" style="text;html=1;align=left;fontSize=9;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="260" height="15" as="geometry"/>
