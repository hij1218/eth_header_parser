        </mxCell>
        <mxCell id="eth_etype" value="&lt;b&gt;EType&lt;/b&gt;&lt;br&gt;2B" style="rounded=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="530" width="60" height="45" as="geometry"/>
