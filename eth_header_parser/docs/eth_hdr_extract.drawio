        </mxCell>
        <mxCell id="w1_b4" value="&lt;b&gt;b4-b5&lt;/b&gt;: raw EtherType" style="rounded=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="190" width="230" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="w1_branch" value="&lt;b&gt;VLAN Branch:&lt;/b&gt;" style="text;html=1;align=left;fontSize=10;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="270" y="225" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="w1_novlan" value="&lt;font color=&quot;#009900&quot;&gt;No VLAN (0x0800/0x86DD/other)&lt;br&gt;&lt;b&gt;→ ethertype_v = 1&lt;/b&gt;&lt;br&gt;+ early IPv4/IPv6 detect&lt;br&gt;+ IHL, DSCP from b6-b7&lt;/font&gt;" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="248" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="w1_vlan" value="&lt;font color=&quot;#9673a6&quot;&gt;VLAN (0x8100 or 0x88A8)&lt;br&gt;vlan1_tci ← b6-b7&lt;br&gt;vlan_state ← &quot;01&quot;&lt;br&gt;&lt;i&gt;defer ethertype to word 2&lt;/i&gt;&lt;/font&gt;" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="315" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="w1_out" value="&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;→ mac_src_v = 1&lt;/b&gt;&lt;/font&gt;" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="380" width="230" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="w1_lat" value="&lt;b&gt;T+2&lt;/b&gt; (SOF1)&lt;br&gt;&lt;b&gt;T+3&lt;/b&gt; (SOF2/3)" style="text;html=1;align=center;fontSize=9;fontColor=#CC6600;fillColor=#FFF9E6;rounded=1;strokeColor=#CCCC99;" vertex="1" parent="1">
          <mxGeometry x="300" y="418" width="170" height="35" as="geometry"/>
        </mxCell>

        <!-- WORD 2 -->
        <mxCell id="w2h" value="&lt;b&gt;Word 2&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="520" y="100" width="220" height="30" as="geometry"/>
