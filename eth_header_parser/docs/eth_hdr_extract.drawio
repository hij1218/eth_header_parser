        <mxCell id="w67" value="" style="rounded=1;fillColor=#FFFFFF;strokeColor=#DDD;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1390" y="140" width="180" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="w6_2v" value="&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;W6: 2 VLAN IPv4:&lt;/b&gt;&lt;br&gt;dst_ip + L4 ports&lt;br&gt;&lt;b&gt;→ ipv4_v = 1&lt;/b&gt;&lt;br&gt;&lt;b&gt;→ l4_ports_v = 1&lt;/b&gt;&lt;/font&gt;" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="150" width="160" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="w6_ip6" value="&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;W6: No VLAN IPv6:&lt;/b&gt;&lt;br&gt;Assemble 128-bit&lt;br&gt;src + dst addresses&lt;br&gt;&lt;b&gt;→ ipv6_v = 1&lt;/b&gt;&lt;br&gt;save l4_sport from b6-b7&lt;/font&gt;" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="222" width="160" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="w7_ip6" value="&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;W7: No VLAN IPv6:&lt;/b&gt;&lt;br&gt;b0-b1: L4 dst port&lt;br&gt;&lt;b&gt;→ l4_ports_v = 1&lt;/b&gt;&lt;/font&gt;" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="310" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="w67_lat" value="&lt;b&gt;T+7&lt;/b&gt; (2V IPv4)&lt;br&gt;&lt;b&gt;T+8&lt;/b&gt; (IPv6)" style="text;html=1;align=center;fontSize=9;fontColor=#CC6600;fillColor=#FFF9E6;rounded=1;strokeColor=#CCCC99;" vertex="1" parent="1">
          <mxGeometry x="1415" y="375" width="130" height="35" as="geometry"/>
