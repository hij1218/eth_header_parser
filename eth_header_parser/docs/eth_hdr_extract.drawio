        </mxCell>
        <mxCell id="w4" value="" style="rounded=1;fillColor=#FFFFFF;strokeColor=#DDD;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="140" width="220" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="w4_0v_ip4" value="&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;No VLAN + IPv4:&lt;/b&gt;&lt;br&gt;b0-b1: dst_ip [15:0]&lt;br&gt;(combine with dst_hi)&lt;br&gt;b2-b3: L4 src port&lt;br&gt;b4-b5: L4 dst port&lt;br&gt;&lt;b&gt;→ ipv4_v = 1&lt;/b&gt;&lt;br&gt;&lt;b&gt;→ l4_ports_v = 1&lt;/b&gt;&lt;/font&gt;" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="150" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="w4_0v_ip6" value="&lt;b&gt;No VLAN + IPv6:&lt;/b&gt;&lt;br&gt;b0-b5: src_addr tail&lt;br&gt;b6-b7: dst_addr [15:0]" style="rounded=0;fillColor=#FFF9E6;strokeColor=#CCCC99;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="268" width="200" height="50" as="geometry"/>
        </mxCell>
