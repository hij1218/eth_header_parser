        </mxCell>
        <mxCell id="w2_1v" value="&lt;font color=&quot;#9673a6&quot;&gt;&lt;b&gt;1 VLAN path:&lt;/b&gt;&lt;/font&gt;&lt;br&gt;b0-b1: real EtherType&lt;br&gt;b2-b3: IPv4 IHL+DSCP&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;→ ethertype_v = 1&lt;/b&gt;&lt;br&gt;vlan_count = &quot;01&quot;&lt;/font&gt;" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="150" width="200" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="w2_qinq" value="&lt;font color=&quot;#9673a6&quot;&gt;If b0-b1 = 0x8100 (QinQ):&lt;br&gt;vlan2_tci ← b2-b3&lt;br&gt;vlan_state ← &quot;10&quot;&lt;br&gt;&lt;i&gt;defer to word 3&lt;/i&gt;&lt;/font&gt;" style="rounded=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="232" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="w2_0v" value="&lt;b&gt;No VLAN path:&lt;/b&gt;&lt;br&gt;IPv4: totlen, proto&lt;br&gt;IPv6: plen, nhdr, src[0:1]" style="rounded=0;fillColor=#FFF9E6;strokeColor=#CCCC99;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="300" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="w2_lat" value="&lt;b&gt;T+3&lt;/b&gt; (1 VLAN)" style="text;html=1;align=center;fontSize=9;fontColor=#CC6600;fillColor=#FFF9E6;rounded=1;strokeColor=#CCCC99;" vertex="1" parent="1">
          <mxGeometry x="560" y="360" width="150" height="25" as="geometry"/>
        </mxCell>

        <!-- WORD 3 -->
        <mxCell id="w3h" value="&lt;b&gt;Word 3&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="750" y="100" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="w3" value="" style="rounded=1;fillColor=#FFFFFF;strokeColor=#DDD;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="140" width="220" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="w3_2v" value="&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;2 VLAN (QinQ) path:&lt;/b&gt;&lt;/font&gt;&lt;br&gt;b0-b1: real EtherType&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;→ ethertype_v = 1&lt;/b&gt;&lt;br&gt;vlan_count = &quot;10&quot;&lt;/font&gt;" style="rounded=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="150" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="w3_1v" value="&lt;b&gt;1 VLAN:&lt;/b&gt; IPv4 proto&lt;br&gt;or IPv6 plen/nhdr" style="rounded=0;fillColor=#FFF9E6;strokeColor=#CCCC99;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="222" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="w3_0v" value="&lt;b&gt;No VLAN:&lt;/b&gt;&lt;br&gt;IPv4: src_ip [31:0]&lt;br&gt;       dst_ip_hi ← b6-b7&lt;br&gt;IPv6: src_addr mid [63:0]" style="rounded=0;fillColor=#FFF9E6;strokeColor=#CCCC99;fontSize=9;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="264" width="200" height="55" as="geometry"/>
        </mxCell>
